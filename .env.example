# ====================================================================
# ummvva-bot — пример переменных окружения. Скопируй в .env и заполни.
# ====================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Ключ шифрования полей с данными пациентов (контент переписки шифруется в БД).
# Используется django-fernet-fields-v2. Сгенерируй командой:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Если оставить пустым — в dev откатывается на SECRET_KEY; для прода задать ОБЯЗАТЕЛЬНО.
FIELD_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# --- PostgreSQL ---
POSTGRES_DB=ummvva
POSTGRES_USER=ummvva
POSTGRES_PASSWORD=ummvva
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Провайдеры (выбор реализации через эти переменные) ---
# whatsapp: mock | evolution | meta
WHATSAPP_PROVIDER=mock
# ai: mock | groq | gemini
AI_PROVIDER=mock

# Секрет webhook приёма входящих (/webhook/whatsapp/). Провайдер передаёт его
# в заголовке X-Webhook-Token или в query ?token=<секрет>. Пусто = проверка
# выключена (dev/mock). Для прода задать и добавить ?token=<секрет> в URL вебхука.
WHATSAPP_WEBHOOK_TOKEN=

# --- AI: Groq (текст + Whisper) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_TEMPERATURE=0.3
# Макс. попыток при 429 / 5xx от Groq (1 = без ретраев, дефолт 3).
AI_MAX_RETRIES=3

# --- AI: Gemini (fallback) ---
GEMINI_API_KEY=

# --- WhatsApp: Evolution API (MVP) ---
# Чтобы включить: WHATSAPP_PROVIDER=evolution (выше) + заполни всё ниже.
# URL инстанса (в docker-сети — имя сервиса, напр. http://evolution:8080;
# с хоста — http://localhost:8080).
EVOLUTION_API_URL=
# Глобальный ключ Evolution (заголовок apikey). В compose Evolution это AUTHENTICATION_API_KEY.
EVOLUTION_API_KEY=
# Имя инстанса, к которому привязан номер клиники по QR.
EVOLUTION_INSTANCE=

# --- WhatsApp: Meta Cloud API (прод) ---
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
