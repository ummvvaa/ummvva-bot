# ====================================================================
# ummvva-bot — пример переменных окружения. Скопируй в .env и заполни.
# ====================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Ключ шифрования полей БД (Fernet). Сгенерируй:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-real-fernet-key

# --- PostgreSQL ---
POSTGRES_DB=ummvva
POSTGRES_USER=ummvva
POSTGRES_PASSWORD=ummvva
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Провайдеры (выбор реализации через эти переменные) ---
# whatsapp: mock | evolution | meta
WHATSAPP_PROVIDER=mock
# ai: mock | groq | gemini
AI_PROVIDER=mock

# --- AI: Groq (текст + Whisper) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_TEMPERATURE=0.3

# --- AI: Gemini (fallback) ---
GEMINI_API_KEY=

# --- WhatsApp: Evolution API (MVP) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- WhatsApp: Meta Cloud API (прод) ---
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
